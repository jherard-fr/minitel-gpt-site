# Bloque tout accès web au dossier de données (hits, géoloc, IP exclues, logs…)
<IfModule mod_alias.c>
  RedirectMatch 403 ^/data/
</IfModule>
<FilesMatch "(hits\.jsonl|geo\.json|exclude_ips\.json|contact-errors\.log|rl_.*\.txt)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Cache : HTML et CSS toujours revalidés (les mises à jour s'affichent tout de
# suite), images et vidéo mises en cache (stables / versionnées via ?v=).
<IfModule mod_headers.c>
  <FilesMatch "\.(html|css|js)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType image/png "access plus 7 days"
  ExpiresByType image/jpeg "access plus 7 days"
  ExpiresByType image/svg+xml "access plus 7 days"
  ExpiresByType video/mp4 "access plus 30 days"
</IfModule>
